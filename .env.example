# ──────────────────────────────────────────────
# Banco de dados (PostgreSQL)
# ──────────────────────────────────────────────
# Produção (Neon.tech, Supabase, ou seu Postgres):
DATABASE_URL="postgresql://user:password@host:5432/agendamentos?sslmode=require"

# Desenvolvimento local (via docker-compose):
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/agendamentos"

# ──────────────────────────────────────────────
# App
# ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://agendamento.solucoesdeia.com"
JWT_SECRET="troque-por-string-aleatoria-longa-minimo-32-chars"

# ──────────────────────────────────────────────
# Cron (Vercel Cron Jobs usa este valor como Bearer token)
# ──────────────────────────────────────────────
CRON_SECRET="troque-por-outro-segredo-aleatorio"
